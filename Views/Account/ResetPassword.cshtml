@using FinalBlog.Models.ViewModels
@model ResetPasswordViewModel
@{
  ViewData["Title"] = "Reset Password";
}

<partial name="_NotificationPartial" />

<div class="container d-flex justify-content-center align-items-center" style="min-height: 50vh;">

  <div class="col-12 col-sm-10 col-md-6 col-lg-5 col-xl-4">

    <div class="card shadow-sm p-4 rounded-3">

      <h3 class="text-center mb-4">Reset Password</h3>

      <form asp-controller="Account" asp-action="ResetPassword" method="post">

        @Html.AntiForgeryToken()

        <!-- TOKEN (hidden) -->
        <input type="hidden" asp-for="Token" />

        <!-- NEW PASSWORD -->
        <div class="mb-3">
          <label asp-for="NewPassword" class="form-label"></label>
          <input asp-for="NewPassword" type="password" class="form-control" placeholder="Enter new password" />
          <span asp-validation-for="NewPassword" class="text-danger"></span>
        </div>

        <!-- CONFIRM PASSWORD -->
        <div class="mb-3">
          <label asp-for="ConfirmPassword" class="form-label"></label>
          <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm password" />
          <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <!-- SUBMIT -->
        <div class="d-grid mb-3">
          <button type="submit" class="btn btn-success">
            Reset Password
          </button>
        </div>

        <!-- BACK -->
        <div class="text-center">
          <a asp-controller="Account" asp-action="Signin" class="text-decoration-none">
            Back to Login
          </a>
        </div>

      </form>

    </div>

  </div>

</div>
@section Scripts {
  @{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
  }
}