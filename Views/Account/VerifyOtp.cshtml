@model OtpVerification
@{
  ViewData["Title"] = "Verify OTP";
}



<div class="container py-5">

  <div class="row justify-content-center align-items-center" style="min-height: 40vh;">

    <div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4">

      <div class="card shadow border-0 rounded-4 p-4">

        <h3 class="text-center mb-3 fw-semibold">
          Verify OTP
        </h3>

        <div class="alert alert-info text-center small">
          We've sent a 6-digit OTP to your email
        </div>

        <form asp-controller="Account" asp-action="VerifyOtp" method="post">

          @Html.AntiForgeryToken()

          <!-- Hidden Email -->
          <input asp-for="Email" type="hidden" />

          <!-- OTP INPUT -->
          <div class="mb-3">
            <label class="form-label fw-medium">OTP Code:</label>
            <input asp-for="OtpCode" class="form-control form-control text-center" maxlength="6"
                   placeholder="Enter 6-digit OTP" autocomplete="on" />
            <span asp-validation-for="OtpCode" class="text-danger"></span>
          </div>

          <!-- VERIFY BUTTON -->
          <div class="d-grid mb-3">
            <button type="submit" class="btn btn-primary fw-medium"
                    onclick="this.innerText='Verifying...'; this.disabled=true;">
              Verify OTP
            </button>
          </div>

          <!-- BACK -->
          <div class="text-center">
            <a asp-controller="Account" asp-action="ForgotPassword" class="text-decoration-none small">
              ← Back
            </a>
          </div>

        </form>

      </div>

    </div>

  </div>

</div>
@section Scripts {
  @{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
  }
}