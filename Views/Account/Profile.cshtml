@model FinalBlog.Models.User

@{
  ViewData["Title"] = "My Profile";
}
@{
  var isAdmin = User.IsInRole("Admin");
}



<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-circle"></i> My Profile</h2>

    @if (User.IsInRole("Admin"))
    {
      <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-dark btn-md">
        Back to Dashboard
      </a>
    }
    else
    {
      <a asp-controller="Blog" asp-action="Index" class="btn btn-dark btn-md">
        Back to Blogs
      </a>
    }
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-4">

      <div class="row align-items-start">

        <!-- LEFT -->
        <div class="col-md-4 text-center">

          <img
          src="@(string.IsNullOrEmpty(Model.ProfileImage) ? Url.Content("~/images/default-profile.png") : Model.ProfileImage)"
          class="rounded-circle img-thumbnail" style="width:150px; height:150px; object-fit:cover;" />

          <h4 class="mt-3">@Model.Username</h4>

          <span class="badge bg-primary">@Model.Role</span>

        </div>

        <!-- RIGHT -->
        <div class="col-md-8 mt-3">

          <table class="table table-borderless">

            <tr>
              <th>Email</th>
              <td>@Model.Email</td>
            </tr>

            <tr>
              <th>Status</th>
              <td>
                @if (Model.IsLocked)
                {
                  <span class="badge bg-danger">Blocked</span>
                }
                else
                {
                  <span class="badge bg-success">Active</span>
                }
              </td>
            </tr>

            <tr>
              <th>Role</th>
              <td>@Model.Role</td>
            </tr>

          </table>

        
          @if (isAdmin)
          {
            <a asp-controller="Account" asp-action="EditProfile" class="btn btn-warning btn-md">
              Edit Profile
            </a>
          }
          else
          {
            <a asp-controller="Account" asp-action="EditProfile" class="btn btn-warning btn-md">
              Edit Profile
            </a>

            <a asp-controller="Account" asp-action="ChangePassword" class="btn btn-secondary btn-md">
              Change Password
            </a>
          }

          
        </div>

      </div>

    </div>
  </div>

  @if (ViewBag.UserActivities != null && ((List<FinalBlog.Models.Activity>)ViewBag.UserActivities).Any())
  {
    <div class="mt-4">
      <h4><i class="bi bi-bell"></i> Recent Notifications</h4>
      <div class="card shadow-sm">
        <div class="card-body">
          @foreach (var activity in (List<FinalBlog.Models.Activity>)ViewBag.UserActivities)
          {
            <div class="d-flex align-items-start mb-3 pb-3 border-bottom">
              <div class="me-3">
                @if (activity.Type == "Blog")
                {
                  <i class="fas fa-blog text-info fa-lg"></i>
                }
                else
                {
                  <i class="fas fa-user text-success fa-lg"></i>
                }
              </div>
              <div class="flex-grow-1">
                <div class="fw-semibold">@activity.Action</div>
                <div class="text-muted small">
                  @if (activity.Type == "Blog" && !string.IsNullOrEmpty(activity.BlogTitle))
                  {
                    <span>Blog: @activity.BlogTitle</span>
                  }
                  <span class="ms-2">@activity.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                </div>
              </div>
            </div>
          }
        </div>
      </div>
    </div>
  }

</div>