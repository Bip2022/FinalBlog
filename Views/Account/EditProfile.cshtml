@model FinalBlog.Models.ViewModels.EditProfileViewModel
@{
  var isAdmin = User.IsInRole("Admin");
}
<partial name="_NotificationPartial" />
<div class="container mt-4">

  <h2>Edit Profile</h2>

  <form asp-controller="Account" asp-action="EditProfile" method="post" enctype="multipart/form-data">
    <div class="mb-3">
      <label>Username</label>
      @if (isAdmin)
      {
        <input asp-for="Username" class="form-control" readonly />
      }
      else
      {
        <input asp-for="Username" class="form-control" />
      }
    </div>
    <div class="mb-3">
      <label>Email</label>
      @if (isAdmin)
      {
        <input asp-for="Email" class="form-control" readonly />
      }
      else
      {
        <input asp-for="Email" class="form-control" />
      }
    </div>

    <div class="mb-3">
      <label>Profile Image</label>
      <input asp-for="ProfileImage" type="file" class="form-control" />

      <div class="mt-2">
        <img
        src="@(string.IsNullOrEmpty(Model.ExistingProfileImage)
                                                                                                                                                                          ? Url.Content("~/images/default-profile.png")
                                                                                                                                                                          : Model.ExistingProfileImage)"
        style="width:100px;height:100px;border-radius:50%;object-fit:cover;" />
      </div>
    </div>

    <button type="submit" class="btn btn-primary">
      Save Changes
    </button>

  </form>

</div>