@model IEnumerable<FinalBlog.Models.Activity>

@{
  ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-4">
  <!-- HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-nowrap">
  
    <h2 class="mb-0">
      <i class="fas fa-tachometer-alt"></i> Admin Dashboard
    </h2>

    <div class="d-flex flex-column flex-sm-row gap-2 ms-2">
      <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-primary btn-md">
        <i class="fas fa-users"></i> Manage Users
      </a>

      <a asp-controller="Admin" asp-action="PendingBlogs" class="btn btn-outline-warning btn-md">
        <i class="fas fa-blog"></i> Pending Blogs
      </a>
      <a asp-controller="Admin" asp-action="AllBlogs" class="btn btn-outline-danger btn-md">
        <i class="fas fa-trash-alt"></i> Delete / manage blogs
      </a>
    </div>

  </div>

  <!-- SUMMARY CARDS -->
  <div class="row mb-4">
    <div class="col-lg-2 col-md-4 mb-3">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-users fa-2x text-primary mb-2"></i>
          <h6>Total Users</h6>
          <h3 class="text-primary">@ViewBag.TotalUsers</h3>
        </div>
      </div>
    </div>
    <div class="col-lg-2 col-md-4 mb-3">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-user-clock fa-2x text-warning mb-2"></i>
          <h6>Pending Users</h6>
          <h3 class="text-warning">@ViewBag.PendingUsers</h3>
        </div>
      </div>
    </div>
    <div class="col-lg-2 col-md-4 mb-3">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-blog fa-2x text-danger mb-2"></i>
          <h6>Pending Blogs</h6>
          <h3 class="text-danger">@ViewBag.PendingBlogs</h3>
        </div>
      </div>
    </div>
    <div class="col-lg-2 col-md-4 mb-3">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-newspaper fa-2x text-success mb-2"></i>
          <h6>Total Blogs</h6>
          <h3 class="text-success">@ViewBag.TotalBlogs</h3>
        </div>
      </div>
    </div>
    <div class="col-lg-2 col-md-4 mb-3">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-comments fa-2x text-info mb-2"></i>
          <h6>Total Comments</h6>
          <h3 class="text-info">@ViewBag.TotalComments</h3>
        </div>
      </div>
    </div>
    <div class="col-lg-2 col-md-4 mb-3">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-heart fa-2x text-danger mb-2"></i>
          <h6>Total Likes</h6>
          <h3 class="text-danger">@ViewBag.TotalLikes</h3>
        </div>
      </div>
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-12">
      <div class="card shadow-sm border border-danger border-opacity-25">
        <div class="card-body d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 py-3">
          <div>
            <h5 class="mb-1">
              <i class="fas fa-trash-alt text-danger me-2"></i>Delete or remove blogs
            </h5>
            <p class="text-muted small mb-0">
              Pending review only has approve/view. When you want to delete any post (draft, waiting for approval, or already live), open the full list and delete from there.
            </p>
          </div>
          <a asp-controller="Admin" asp-action="AllBlogs" class="btn btn-danger px-4 flex-shrink-0">
            <i class="fas fa-newspaper me-1"></i> Open blog list
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-8 mb-4">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
          <h5 class="mb-0"><i class="fas fa-history me-2"></i> Recent Activities</h5>
        </div>
        <div class="card-body">
          @if (Model != null && Model.Any())
          {
            <div class="row g-3">
              @foreach (var item in Model)
              {
                <div class="col-12">
                  <div class="card border-0 shadow-sm bg-light">
                    <div class="card-body p-3 d-flex justify-content-between align-items-start gap-3">
                      <div class="d-flex align-items-start gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center bg-light border"
                             style="width: 52px; height: 52px;">
                          @if (item.Type == "Blog")
                          {
                            <i class="fas fa-pen-fancy text-info"></i>
                          }
                          else
                          {
                            <i class="fas fa-user text-success"></i>
                          }
                        </div>
                        <div>
                          <div class="fw-semibold mb-1">@item.Action</div>
                          <div class="small text-muted">
                            @if (item.Type == "Blog")
                            {
                              <span class="badge bg-info text-dark me-2">Blog</span>
                              @item.BlogTitle
                            }
                            else
                            {
                              <span class="badge bg-success text-dark me-2">User</span>
                              <span>by @item.Username</span>
                            }
                          </div>
                        </div>
                      </div>
                      <div class="text-end small text-muted">
                        <div><i class="far fa-calendar-alt me-1"></i>@item.CreatedAt.ToString("MMM dd")</div>
                        <div><i class="far fa-clock me-1"></i>@item.CreatedAt.ToString("HH:mm")</div>
                      </div>
                    </div>
                  </div>
                </div>
              }
            </div>
          }
          else
          {
            <div class="p-5 text-center text-muted">
              <i class="fas fa-inbox fa-3x mb-3 text-light"></i>
              <p class="mb-0">No recent activity yet.</p>
            </div>
          }
        </div>
        <div class="card-footer bg-white text-center border-0 py-3">
          <a asp-controller="Admin" asp-action="Logs" class="btn btn-sm btn-outline-primary rounded-pill px-4">
            View All Activity
          </a>
        </div>
      </div>
    </div>

    <div class="col-lg-4 mb-4">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-success text-white">
          <i class="fas fa-bolt"></i> Quick Actions
        </div>
        <div class="card-body">
          <div class="d-grid gap-2">
            <a asp-controller="Admin" asp-action="PendingUsers" class="btn btn-outline-warning">
              <i class="fas fa-user-check"></i> Review Pending Users (@ViewBag.PendingUsers)
            </a>
            <a asp-controller="Admin" asp-action="PendingBlogs" class="btn btn-outline-danger">
              <i class="fas fa-blog"></i> Review Pending Blogs (@ViewBag.PendingBlogs)
            </a>
            <a asp-controller="Admin" asp-action="AllBlogs" class="btn btn-outline-danger">
              <i class="fas fa-trash-alt"></i> Delete / manage blogs (full list)
            </a>
            <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-primary">
              <i class="fas fa-users-cog"></i> Manage All Users
            </a>
            <a asp-controller="Blog" asp-action="Index" class="btn btn-outline-info">
              <i class="fas fa-eye"></i> View Blog Posts
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
}