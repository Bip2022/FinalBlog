@model List<FinalBlog.Models.Blog>

@{
  ViewData["Title"] = "Pending Blogs";
}

<!-- NOTIFICATION -->
<partial name="_NotificationPartial" />

<!-- HEADER -->
<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">

  <h2 class="mb-0">📝 Pending Blogs</h2>

  <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-dark btn-md rounded-pill">
    ⬅ Back to Dashboard
  </a>

</div>

<hr />

<!-- TABLE WRAPPER -->
<div class="table-responsive">

  <table class="table table-bordered table-hover align-middle">

    <thead class="table-dark">
      <tr>
        <th><i class="bi bi-card-text"></i> Title</th>
        <th><i class="bi bi-person"></i> Author</th>
        <th><i class="bi bi-tags"></i> Category</th>
        <th><i class="bi bi-calendar"></i> Created</th>
        <th><i class="bi bi-hourglass-split"></i> Status</th>
        <th><i class="bi bi-gear"></i> Action</th>
      </tr>
    </thead>

    <tbody>
      @foreach (var blog in Model)
      {
        <tr>
          <td data-label="Title">@blog.Title</td>
          <td data-label="Author">@blog.Author</td>
          <td data-label="Category">@blog.Category?.Name</td>
          <td data-label="Created Date">@blog.CreatedDate.ToShortDateString()</td>

          <td data-label="Status">
            <span class="badge bg-warning text-dark">
              <i class="bi bi-clock"></i> Pending
            </span>
          </td>

          <td data-label="Action">
            <a asp-controller="Admin" asp-action="ViewPendingBlog" asp-route-id="@blog.Id"
               class="btn btn-primary btn-sm me-1">
              <i class="bi bi-eye"></i> View
            </a>
            <a asp-controller="Admin" asp-action="ApproveBlog" asp-route-id="@blog.Id" class="btn btn-success btn-sm">
              <i class="bi bi-check-circle"></i> Approve
            </a>
          </td>
        </tr>
      }
    </tbody>

  </table>

</div>