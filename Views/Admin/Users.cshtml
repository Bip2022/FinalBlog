@model List<FinalBlog.Models.User>

@{
  ViewData["Title"] = "Users";
}

<!-- TOAST NOTIFICATION -->
<partial name="_NotificationPartial" />

<!-- HEADER -->
<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">

  <h2 class="mb-0">👥 Users</h2>

  <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-dark btn-md rounded-pill">
    ⬅ Back to Dashboard
  </a>

</div>

<hr />

<!-- TABLE WRAPPER -->
<div class="table-responsive">

  <table class="table table-bordered table-hover align-middle">

    <thead class="table-dark">
      <tr>
        <th><i class="bi bi-person"></i> Username</th>
        <th><i class="bi bi-envelope"></i> Email</th>
        <th><i class="bi bi-shield"></i> Role</th>
        <th><i class="bi bi-info-circle"></i> Status</th>
        <th><i class="bi bi-gear"></i> Action</th>
      </tr>
    </thead>

    <tbody>
      @foreach (var user in Model)
      {
        <tr>
          <td data-label="Username">@user.Username</td>
          <td data-label="Email">@user.Email</td>
          <td data-label="Role">@user.Role</td>

          <!-- STATUS -->
          <td data-label="Status">
            @if (user.IsLocked)
            {
              <span class="badge bg-danger">
                <i class="bi bi-lock-fill"></i> Blocked
              </span>
            }
            else
            {
              <span class="badge bg-success">
                <i class="bi bi-check-circle"></i> Active
              </span>
            }
          </td>

          <!-- ACTION -->
          <td data-label="Action">
            @if (user.Username == User.Identity?.Name)
            {
              <span class="text-muted">
                <i class="bi bi-person-check"></i> Current Admin
              </span>
            }
            else if (user.IsLocked)
            {
              <a asp-action="UnlockUser" asp-route-id="@user.Id" class="btn btn-success btn-sm">
              
                <i class="bi bi-unlock"></i> Unblock
              </a>
            }
            else
            {
              <a asp-action="LockUser" asp-route-id="@user.Id" class="btn btn-warning btn-sm">

                <i class="bi bi-lock"></i> Block
              </a>
            }
          </td>
        </tr>
      }
    </tbody>

  </table>

</div>