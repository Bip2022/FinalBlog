@model List<FinalBlog.Models.User>

@{
    ViewData["Title"] = "Pending Users";
}



<!-- HEADER -->
<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2">

    <h2 class="mb-0">⏳ Pending Users</h2>

    <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-dark btn-md rounded-pill">
        ⬅ Back to Dashboard
    </a>

</div>

<hr />

<!-- TABLE WRAPPER FOR MOBILE SCROLL -->
<div class="table-responsive">

    <table class="table table-bordered table-hover align-middle">

        <thead class="table-dark">
            <tr>
                <th><i class="bi bi-person"></i> Username</th>
                <th><i class="bi bi-envelope"></i> Email</th>
                <th><i class="bi bi-shield"></i> Role</th>
                <th><i class="bi bi-hourglass-split"></i> Status</th>
                <th><i class="bi bi-gear"></i> Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td data-label="Username">@user.Username</td>
                    <td data-label="Email">@user.Email</td>
                    <td data-label="Role">@user.Role</td>

                    <td data-label="Status">
                        <span class="badge bg-warning text-dark">
                            <i class="bi bi-clock"></i> Pending
                        </span>
                    </td>

                    <td data-label="Action">
                        <a asp-controller="Admin" asp-action="ApproveUser" asp-route-id="@user.Id"
                               class="btn btn-success btn-sm">
                           <i class="bi bi-check-circle"></i> Approve
                        </a>
                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>