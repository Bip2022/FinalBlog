@model FinalBlog.Models.ViewModels.BlogDetailsViewModel

@{
    ViewData["Title"] = Model.Blog.Title;
    var canLike = User.Identity?.IsAuthenticated == true && (User.IsInRole("User") || User.IsInRole("Admin"));
    var canComment = User.Identity?.IsAuthenticated == true && (User.IsInRole("User") || User.IsInRole("Admin"));

    string? NormalizeImageUrl(string? imagePath)
    {
        if (string.IsNullOrWhiteSpace(imagePath)) return null;

        if (imagePath.StartsWith("/images/")) return imagePath;
        if (imagePath.StartsWith("~/")) return Url.Content(imagePath);

        if (imagePath.Contains("wwwroot"))
        {
            var wwwrootIndex = imagePath.IndexOf("wwwroot", StringComparison.OrdinalIgnoreCase);
            var relativePath = imagePath[(wwwrootIndex + "wwwroot".Length)..];
            return relativePath.Replace('\\', '/');
        }

        if (!imagePath.StartsWith("/")) imagePath = "/" + imagePath;
        return imagePath;
    }
}



<div class="container-fluid mt-4">
    <div class="row gx-4">
        <!-- MAIN CONTENT -->
        <div class="col-lg-9">
            <!-- BREADCRUMB -->
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Blog</a></li>
                    @if (Model.Blog.Category != null)
                    {
                        <li class="breadcrumb-item"><a asp-action="ByCategory"
                                                           asp-route-id="@Model.Blog.CategoryId">@Model.Blog.Category.Name</a></li>
                        }
                        <li class="breadcrumb-item active">@Model.Blog.Title</li>
                    </ol>
                </nav>

                <!-- BLOG POST -->
                <article class="card border-0 shadow-sm mb-4">
                    @if (!string.IsNullOrEmpty(Model.Blog.ImagePath))
                    {
                        <img src="@NormalizeImageUrl(Model.Blog.ImagePath)" class="card-img-top" alt="@Model.Blog.Title"
                             style="object-fit: cover; height: 400px;" />
                    }

                    <div class="card-body">
                        <!-- HEADER -->
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                            @if (Model.Blog.Category != null)
                            {
                                <a asp-action="ByCategory" asp-route-id="@Model.Blog.CategoryId"
                                   class="badge bg-primary text-decoration-none">@Model.Blog.Category.Name</a>
                            }
                            <small class="text-muted">by @Model.Blog.Author</small>
                            <small class="text-muted">• @Model.Blog.CreatedDate.ToString("MMM dd, yyyy")</small>
                        </div>

                        <!-- TITLE -->
                        <h1 class="h2 card-title mb-4">@Model.Blog.Title</h1>

                        <!-- CONTENT -->
                        <div class="blog-content mb-4">
                            @Html.Raw(Model.Blog.Text.Replace("\n", "<br />"))
                        </div>

                        <!-- LIKE BUTTON -->
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-muted small">
                                        <i class="fas fa-heart text-danger me-1"></i><span id="like-count">@Model.Blog.LikeCount</span> Likes
                                    </span>
                                 @if (canLike)
                                 {
                                      <button type="button"
                                              id="like-btn"
                                              data-blog-id="@Model.Blog.Id"
                                              data-is-liked="@Model.IsLikedByCurrentUser.ToString().ToLower()"
                                              class="btn btn-sm @(Model.IsLikedByCurrentUser ? "btn-danger" : "btn-outline-danger") rounded-pill py-0 px-2"
                                              onclick="event.preventDefault(); toggleLike(this); return false;">
                                         @if (Model.IsLikedByCurrentUser)
                                         {
                                             <text><i class="fas fa-heart"></i></text>
                                         }
                                         else
                                         {
                                             <text><i class="far fa-heart"></i></text>
                                         }
                                     </button>
                                 }
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Blog</a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Delete" asp-route-id="@Model.Blog.Id" class="btn btn-danger btn-sm">Delete
                                        Blog</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </article>

                    <!-- COMMENTS SECTION -->
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Comments (@(Model.Blog.Comments?.Count ?? 0))</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.Blog.Comments != null && Model.Blog.Comments.Any())
                            {
                                @foreach (var comment in Model.Blog.Comments.OrderByDescending(c => c.CommentDate))
                                {
                                    <div class="comment mb-3 pb-3 border-bottom">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="flex-grow-1">
                                                <div class="fw-semibold small text-primary">@comment.UserName</div>
                                                <div class="comment-text mt-1">@Html.Raw(comment.Text.Replace("\n", "<br />"))</div>
                                            </div>
                                            <small class="text-muted ms-2 flex-shrink-0">@comment.CommentDate.ToString("MMM dd, yyyy HH:mm")</small>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-muted text-center py-4">
                                    <i class="fas fa-comments fa-2x mb-2"></i>
                                    <p>No comments yet. Be the first to share your thoughts!</p>
                                </div>
                            }
                        </div>

                        @if (canComment)
                        {
                            <div class="card-footer bg-light">
                                <h6>Add a Comment</h6>
                                <form asp-action="AddComment" method="post" class="mt-3">
                                    <input type="hidden" name="blogId" value="@Model.Blog.Id" />
                                    <div class="mb-3">
                                        <textarea name="text" class="form-control" rows="3" placeholder="Share your thoughts..."
                                                  maxlength="500" required></textarea>
                                        <div class="form-text">Maximum 500 characters</div>
                                    </div>
                                    <button type="submit" class="btn btn-primary btn-sm">Post Comment</button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <div class="card-footer bg-light text-center">
                                <a asp-controller="Account" asp-action="Signin"
                                       asp-route-returnUrl="@Url.Action("Details", "Blog", new { id = Model.Blog.Id })"
                                       class="text-decoration-none">
                                    <i class="fas fa-sign-in-alt me-1"></i>Sign in to leave a comment
                                </a>
                            </div>
                        }
                    </div>
                </div>

                <!-- SIDEBAR -->
                <div class="col-lg-3">
                    <div class="card mb-4 shadow-sm border-0">
                        <div class="card-header bg-white border-bottom">
                            <h5 class="mb-0">Categories</h5>
                        </div>
                        <div class="list-group list-group-flush">
                            @if (ViewBag.Categories is List<FinalBlog.Models.Category> categories && categories.Any())
                            {
                                @foreach (var category in categories)
                                {
                                    <a asp-action="ByCategory" asp-route-id="@category.Id"
                                           class="list-group-item list-group-item-action text-start">
                                        @category.Name
                                    </a>
                                }
                            }
                            else
                            {
                                <div class="list-group-item text-muted">No categories found.</div>
                            }
                        </div>
                    </div>

                    <div class="card mb-4 shadow-sm border-0">
                        <div class="card-header bg-white border-bottom">
                            <h5 class="mb-0">Trending Blogs</h5>
                        </div>
                        <div class="list-group list-group-flush">
                            @if (ViewBag.TrendingBlogs is List<FinalBlog.Models.Blog> trending && trending.Any())
                            {
                                @foreach (var item in trending)
                                {
                                    <a asp-action="Details" asp-route-id="@item.Id" class="list-group-item list-group-item-action">
                                        <div class="fw-semibold">@item.Title</div>
                                        <small class="text-muted">@item.Category?.Name • @item.LikeCount Likes</small>
                                    </a>
                                }
                            }
                            else
                            {
                                <div class="list-group-item text-muted">No trending blogs yet.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @section Scripts {
            @Html.AntiForgeryToken()
            <script>
                async function toggleLike(button) {
                    const blogId = button.getAttribute('data-blog-id');

                    try {
                        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                        const params = new URLSearchParams();
                        params.append('blogId', blogId);
                        params.append('__RequestVerificationToken', token);

                        const response = await fetch('/Blog/ToggleLike', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded'
                            },
                            body: params.toString()
                        });

                        if (!response.ok) {
                            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                        }

                        const result = await response.json();

                        if (result.success) {
                            // Update button state based on server response
                            button.setAttribute('data-is-liked', result.liked.toString());

                            // Update like count
                            const likeCountEl = document.getElementById('like-count');
                            if (likeCountEl) {
                                likeCountEl.textContent = result.likeCount;
                            }

                            if (result.liked) {
                                // Now liked
                                button.className = 'btn btn-sm btn-danger rounded-pill py-0 px-2';
                                button.innerHTML = '<i class="fas fa-heart"></i>';
                                toastr.success(result.message);
                            } else {
                                // Now unliked
                                button.className = 'btn btn-sm btn-outline-danger rounded-pill py-0 px-2';
                                button.innerHTML = '<i class="far fa-heart"></i>';
                                toastr.info(result.message);
                            }
                        } else {
                            toastr.error(result.message || 'An error occurred.');
                        }
                    } catch (error) {
                        console.error('AJAX Error:', error);
                        toastr.error('An error occurred while processing your request.');
                    }
                }
            </script>
        }