@model IEnumerable<FinalBlog.Models.Blog>

@{
    ViewData["Title"] = "Blog";

    var likedSet = ViewBag.LikedBlogIds as HashSet<int> ?? new HashSet<int>();
    var canLike = User.Identity?.IsAuthenticated == true && (User.IsInRole("User") || User.IsInRole("Admin"));
    var canReadFull = User.Identity?.IsAuthenticated == true && (User.IsInRole("User") || User.IsInRole("Admin"));
    var listReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    string? NormalizeImageUrl(string? imagePath)
    {
        if (string.IsNullOrWhiteSpace(imagePath)) return null;

        var p = imagePath.Trim();

        // fix physical paths if any
        if (p.Contains("wwwroot"))
        {
            var index = p.IndexOf("wwwroot", StringComparison.OrdinalIgnoreCase);
            p = p[(index + "wwwroot".Length)..];
        }

        p = p.Replace("\\", "/");

        if (!p.StartsWith("/")) p = "/" + p;

        return Url.Content("~" + p);
    }
}

<div class="container-fluid mt-4">
    <div class="row gx-4">

        <!-- LEFT: BLOG LIST -->
        <div class="col-lg-9">

            <div class="mb-4 d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-1">Latest Blog Posts</h1>
                    <p class="text-muted mb-0">
                        @if (canReadFull)
                        {
                            <text>Read the newest stories and updates from the blog.</text>
                        }
                        else
                        {
                            <text>
                                Browse titles here.
                                <a asp-controller="Account" asp-action="Signin">Sign in</a> to read full posts.
                            </text>
                        }
                    </p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">All posts</a>
            </div>

            @if (Model != null && Model.Any())
            {
                foreach (var blog in Model)
                {
                    <div class="card mb-4 shadow-sm border-0">

                        @if (!string.IsNullOrEmpty(blog.ImagePath))
                        {
                            <img src="@NormalizeImageUrl(blog.ImagePath)" class="card-img-top"
                                 style="height:280px; object-fit:cover;" alt="@blog.Title" />
                        }

                        <div class="card-body">

                            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                @if (blog.Category != null)
                                {
                                    <span class="badge bg-primary">@blog.Category.Name</span>
                                }
                                <small class="text-muted">by @blog.Author</small>
                                <small class="text-muted">• @blog.CreatedDate.ToString("MMM dd, yyyy")</small>
                            </div>

                            <h3 class="h5">@blog.Title</h3>

                             @if (canReadFull)
                             {
                                 <p class="text-muted">
                                     @Html.Raw(blog.Text?.Length > 150 ? blog.Text.Substring(0, 150) + "..." : blog.Text)
                                 </p>
                             }
                            else
                            {
                                <p class="text-muted small">Sign in to read full content.</p>
                            }

                            <div class="d-flex justify-content-between align-items-center">

                                @if (canReadFull)
                                {
                                    <a asp-action="Details" asp-route-id="@blog.Id" class="btn btn-primary btn-sm">Read more</a>
                                }
                                else
                                {
                                    <a asp-controller="Account" asp-action="Signin"
                                           asp-route-returnUrl="@Url.Action("Details", "Blog", new { id = blog.Id })"
                                           class="btn btn-primary btn-sm">
                                        Sign in
                                    </a>
                                }

                                 <div class="d-flex align-items-center gap-2">
                                     <span class="text-muted small">
                                         ❤️ <span id="like-count-@blog.Id">@blog.LikeCount</span>
                                     </span>

                                     @if (canLike)
                                     {
                                         var liked = likedSet.Contains(blog.Id);

                                         <button type="button"
                                                 id="like-btn-@blog.Id"
                                                 data-blog-id="@blog.Id"
                                                 data-is-liked="@liked.ToString().ToLower()"
                                                 class="btn btn-sm @(liked ? "btn-danger" : "btn-outline-danger")"
                                                 onclick="event.preventDefault(); toggleLike(this); return false;">
                                             @(liked ? "♥" : "♡")
                                         </button>
                                     }
                                </div>

                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info">
                    No blogs available.
                </div>
            }

        </div>

        <!-- RIGHT SIDEBAR -->
        <div class="col-lg-3">

            <div class="card mb-4">
                <div class="card-header">
                    <h5>Categories</h5>
                </div>
                <div class="list-group list-group-flush">
                    @if (ViewBag.Categories is List<FinalBlog.Models.Category> categories && categories.Any())
                    {
                        foreach (var cat in categories)
                        {
                            <a asp-action="ByCategory" asp-route-id="@cat.Id" class="list-group-item list-group-item-action">
                                @cat.Name
                            </a>
                        }
                    }
                    else
                    {
                        <div class="list-group-item text-muted">No categories</div>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5>Trending</h5>
                </div>
                <div class="list-group list-group-flush">
                    @if (ViewBag.TrendingBlogs is List<FinalBlog.Models.Blog> trending && trending.Any())
                    {
                        foreach (var item in trending)
                        {
                            <a asp-action="Details" asp-route-id="@item.Id" class="list-group-item list-group-item-action">
                                @item.Title
                            </a>
                        }
                    }
                    else
                    {
                        <div class="list-group-item text-muted">No trending blogs</div>
                    }
                </div>
            </div>

        </div>

    </div>
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        async function toggleLike(button) {
            const blogId = button.getAttribute('data-blog-id');

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const params = new URLSearchParams();
                params.append('blogId', blogId);
                params.append('__RequestVerificationToken', token);

                const response = await fetch('/Blog/ToggleLike', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: params.toString()
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }

                const result = await response.json();

                if (result.success) {
                    // Update button state based on server response
                    button.setAttribute('data-is-liked', result.liked.toString());

                    // Update like count
                    const likeCountEl = document.getElementById('like-count-' + blogId);
                    if (likeCountEl) {
                        likeCountEl.textContent = result.likeCount;
                    }

                    if (result.liked) {
                        // Now liked
                        button.className = 'btn btn-sm btn-danger';
                        button.innerHTML = '♥';
                        toastr.success(result.message);
                    } else {
                        // Now unliked
                        button.className = 'btn btn-sm btn-outline-danger';
                        button.innerHTML = '♡';
                        toastr.info(result.message);
                    }
                } else {
                    toastr.error(result.message || 'An error occurred.');
                }
            } catch (error) {
                console.error('AJAX Error:', error);
                toastr.error('An error occurred while processing your request.');
            }
        }
    </script>
}